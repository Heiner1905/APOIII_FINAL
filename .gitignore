# =====================================================================
# .gitignore — Proyecto clasificación de calidad de frutas
# =====================================================================

# --- Dataset (pesado: ~3.3 GB, NO se versiona) ---
# Ver README.md para instrucciones de cómo obtener/colocar el dataset.
/Fruits/

# --- Entornos virtuales ---
.venv/
venv/
env/
ENV/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.Python
build/
dist/

# --- Jupyter ---
.ipynb_checkpoints/

# --- Artefactos de modelos (pesados / regenerables) ---
# Los resultados/figuras se renderizan inline en los notebooks; los pesos de
# modelos (binarios) no se versionan.
*.h5
*.keras
*.pkl
*.joblib

# --- Sistema operativo / editores ---
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# --- Datos procesados intermedios ---
data/processed/
*.npy
*.npz
/reports

# --- Artefactos de salida (regenerables con notebooks) ---
/artifacts/

# --- Archivos de presentación / grabación de video (internos) ---
*.pptx
build_presentation.py
Guion_por_Diapositiva.md
Plan_Grabacion_Video.md
presentation_assets/
~$*
